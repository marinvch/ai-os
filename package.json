{
  "name": "ai-os",
  "version": "0.12.2",
  "description": "Portable AI OS — scans any repo and generates optimized GitHub Copilot context, agents, skills, MCP tools, and slash-command prompts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ai-os": "./bundle/generate.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "dev": "tsx src/generate.ts",
    "generate": "tsx src/generate.ts",
    "generate:dry": "tsx src/generate.ts --dry-run",
    "generate:refresh": "tsx src/generate.ts --refresh-existing",
    "bootstrap": "tsx src/generate.ts --bootstrap",
    "bootstrap:dry": "tsx src/generate.ts --bootstrap --dry-run",
    "update": "tsx src/generate.ts --update",
    "update:projects": "bash scripts/update-projects.sh",
    "check-hygiene": "tsx src/generate.ts --check-hygiene",
    "doctor": "tsx src/generate.ts --doctor",
    "check-freshness": "tsx src/generate.ts --check-freshness",
    "compact-memory": "tsx src/generate.ts --compact-memory",
    "validate": "tsx src/validation/regression.ts",
    "validate:smoke": "tsx src/validation/smoke.ts",
    "scorecard:update": "tsx src/validation/scorecard.ts",
    "scorecard:show": "tsx src/validation/scorecard.ts --show",
    "scorecard:check": "tsx src/validation/scorecard-check.ts",
    "validate:fast": "npm run build && npm run test",
    "validate:ops": "npm run validate:fast && npm run scorecard:check",
    "validate:full": "npm run build && npm run test && npm run validate",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:skill-creator": "npx -y skills add anthropics/skills@skill-creator -g -a github-copilot",
    "install:find-skills": "npx -y skills add vercel-labs/skills@find-skills -g -a github-copilot",
    "install:skills": "npm run install:skill-creator && npm run install:find-skills"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
