# AI OS local environment template
# Keep real values in your local .env (never commit secrets).

# Optional: override source repo for bootstrap installs.
# AI_OS_REPO_URL=https://github.com/marinvch/ai-os.git

# Optional: absolute path to Node executable used by install.sh when needed.
# AI_OS_NODE_PATH=

# Optional: force MCP healthcheck/debug diagnostics in local runs.
# AI_OS_MCP_DEBUG=1

# Optional: set MCP runtime root manually for local testing.
# AI_OS_ROOT=.
